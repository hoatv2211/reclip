{
  "name": "reclip-api",
  "services": [
    {
      "type": "web",
      "env": "python",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "python app.py",
      "envVars": [
        {
          "key": "PORT",
          "value": "8080"
        },
        {
          "key": "HOST",
          "value": "0.0.0.0"
        }
      ]
    }
  ]
}
